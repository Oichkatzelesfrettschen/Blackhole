# ==============================================================================
# Blackhole .gitignore -- only build artifacts, caches, and editor junk
# ==============================================================================

# ------------------------------------------------------------------------------
# Build directories
# ------------------------------------------------------------------------------
/build/
/build-*/
/build_*/
/install/

# ------------------------------------------------------------------------------
# C/C++ object files and libraries produced by the build
# ------------------------------------------------------------------------------
*.o
*.obj
*.lo
*.slo
*.a
*.lib
*.lai
*.la
*.so
*.so.*
*.dylib
*.dll
*.exe
*.out
*.app
*.elf

# Precompiled headers
*.gch
*.pch

# Debug symbols
*.dSYM/
*.su

# ------------------------------------------------------------------------------
# CUDA build artifacts
# ------------------------------------------------------------------------------
*.ptx
*.cubin
*.fatbin
*.gpu

# ------------------------------------------------------------------------------
# CMake generated files
# ------------------------------------------------------------------------------
CMakeCache.txt
CMakeFiles/
cmake_install.cmake
compile_commands.json
Makefile
*.cmake
!cmake/ValidateShader.cmake
CMakeUserPresets.json

# ------------------------------------------------------------------------------
# Conan repo-local cache (packages are rebuilt, config is versioned)
# ------------------------------------------------------------------------------
.conan/*
!.conan/global.conf
!.conan/remotes.json

# ------------------------------------------------------------------------------
# Shader binaries (SPIR-V)
# ------------------------------------------------------------------------------
*.spv

# ------------------------------------------------------------------------------
# Profiling / analysis outputs
# ------------------------------------------------------------------------------
perf.data
perf.data.old
gmon.out
infer-out/
captures/
logs/

# ------------------------------------------------------------------------------
# Test binaries (prevent accidental commits of compiled tests)
# ------------------------------------------------------------------------------
src/**/physics_test
src/**/*_test
tests/*_test
!tests/*_test.cpp

# ------------------------------------------------------------------------------
# Python caches
# ------------------------------------------------------------------------------
__pycache__/
*.pyc
*.pyo
.venv/

# ------------------------------------------------------------------------------
# Blender backup/temp files (project .blend files ARE tracked)
# ------------------------------------------------------------------------------
*.blend1
*.blend2

# ------------------------------------------------------------------------------
# Editor / IDE
# ------------------------------------------------------------------------------
.idea/
.vscode/
*.swp
*.swo
*~
*.code-workspace

# ------------------------------------------------------------------------------
# OS junk
# ------------------------------------------------------------------------------
.DS_Store
.AppleDouble
.LSOverride
._*

# ------------------------------------------------------------------------------
# Misc temp / cache
# ------------------------------------------------------------------------------
*.tmp
*.temp
*.bak
*.log
*.db
settings.json
imgui.ini
.cache/
