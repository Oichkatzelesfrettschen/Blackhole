# Doxyfile.in -- Doxygen configuration with CMake variable substitution
# Generated Doxyfile lives at @CMAKE_BINARY_DIR@/Doxyfile

# ---------------------------------------------------------------------------
# Project
# ---------------------------------------------------------------------------
PROJECT_NAME           = @CMAKE_PROJECT_NAME@
PROJECT_NUMBER         = @CMAKE_PROJECT_VERSION@
PROJECT_BRIEF          = "Physically accurate black hole ray tracer"
OUTPUT_DIRECTORY       = @CMAKE_BINARY_DIR@/docs/api
STRIP_FROM_PATH        = @PROJECT_SOURCE_DIR@

# ---------------------------------------------------------------------------
# Input
# ---------------------------------------------------------------------------
INPUT                  = @PROJECT_SOURCE_DIR@/src \
                         @PROJECT_SOURCE_DIR@/docs/api-mainpage.md \
                         @PROJECT_SOURCE_DIR@/shader \
                         @PROJECT_SOURCE_DIR@/tools \
                         @PROJECT_SOURCE_DIR@/bench
RECURSIVE              = YES
FILE_PATTERNS          = *.h *.cpp *.cu *.cuh *.glsl *.vert *.frag *.comp
EXCLUDE_PATTERNS       = */tests/* */_deps/* */stb_image* */imgui_impl_* */gcovr/* */external/* */build/* */blender_addon/*
USE_MDFILE_AS_MAINPAGE = @PROJECT_SOURCE_DIR@/docs/api-mainpage.md

# ---------------------------------------------------------------------------
# Extraction
# ---------------------------------------------------------------------------
EXTRACT_ALL            = YES
EXTRACT_PRIVATE        = NO
EXTRACT_STATIC         = YES
EXTRACT_LOCAL_CLASSES  = YES

# ---------------------------------------------------------------------------
# Warnings
# ---------------------------------------------------------------------------
WARN_IF_UNDOCUMENTED   = YES
WARN_NO_PARAMDOC       = YES
WARN_AS_ERROR          = @DOXYGEN_WARN_AS_ERROR@
WARN_FORMAT            = "$file:$line: $text"

# ---------------------------------------------------------------------------
# Output formats
# ---------------------------------------------------------------------------
GENERATE_HTML          = YES
HTML_OUTPUT            = html
HTML_DYNAMIC_SECTIONS  = YES
GENERATE_LATEX         = NO
GENERATE_XML           = @DOXYGEN_GENERATE_XML@

# ---------------------------------------------------------------------------
# Source browsing
# ---------------------------------------------------------------------------
SOURCE_BROWSER         = YES
INLINE_SOURCES         = NO
REFERENCED_BY_RELATION = YES
REFERENCES_RELATION    = YES

# ---------------------------------------------------------------------------
# Graphs (requires Graphviz dot)
# ---------------------------------------------------------------------------
HAVE_DOT               = @DOXYGEN_HAVE_DOT@
DOT_PATH               = @DOXYGEN_DOT_PATH@
CALL_GRAPH             = YES
CALLER_GRAPH           = YES
DOT_IMAGE_FORMAT       = svg
INTERACTIVE_SVG        = YES
DOT_GRAPH_MAX_NODES    = 100
DOT_MULTI_TARGETS      = YES

# ---------------------------------------------------------------------------
# Preprocessor
# ---------------------------------------------------------------------------
ENABLE_PREPROCESSING   = YES
MACRO_EXPANSION        = YES
PREDEFINED             = BLACKHOLE_CXX23=1 \
                         BLACKHOLE_HAS_CFITSIO=1 \
                         ENABLE_CUDA=1 \
                         __CUDACC__=1

# ---------------------------------------------------------------------------
# Miscellaneous
# ---------------------------------------------------------------------------
QUIET                  = NO
TAB_SIZE               = 4
MARKDOWN_SUPPORT       = YES
AUTOLINK_SUPPORT       = NO
BUILTIN_STL_SUPPORT    = YES
TYPEDEF_HIDES_STRUCT   = YES
SORT_MEMBER_DOCS       = YES
SORT_BRIEF_DOCS        = YES
